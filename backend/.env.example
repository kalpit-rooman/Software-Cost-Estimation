# ============================================================
# Software Cost Estimator – Backend Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---------------------------------------------------------------------------
# Runtime mode
# ---------------------------------------------------------------------------
# "model" – use saved ML baseline models (default, no API key required)
# "ai"    – use an AI provider for estimation
PREDICTION_MODE=model

# ---------------------------------------------------------------------------
# AI provider settings (required when PREDICTION_MODE=ai)
# ---------------------------------------------------------------------------
# Which AI provider to use: "openai" | "gemini"
AI_PROVIDER=openai

# Model name (leave empty to use the adapter default)
# OpenAI/Groq examples: gpt-4o-mini, gpt-4o, llama3-8b-8192
# Gemini examples: gemini-1.5-flash, gemini-1.5-pro
AI_MODEL=gpt-4o-mini

# OpenAI-compatible API key (used when AI_PROVIDER=openai or any compatible host)
OPENAI_API_KEY=sk-...

# Override base URL for Groq, Mistral, Together AI, or local Ollama shim.
# Leave empty to use the official OpenAI endpoint.
OPENAI_BASE_URL=

# Groq API key – used as a fallback when OPENAI_API_KEY is not set
GROQ_API_KEY=gsk_...

# Google Gemini API key (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=AIza...

# Prompt profile: conservative | balanced | optimistic
AI_PROFILE=balanced

# ---------------------------------------------------------------------------
# Cost / currency settings
# ---------------------------------------------------------------------------
# Blended monthly rate per person in INR.
# Change this to reflect your team's actual monthly blended cost.
DEFAULT_MONTHLY_RATE_INR=150000

# ---------------------------------------------------------------------------
# Intake cache (recommended for production multi-worker deployments)
# ---------------------------------------------------------------------------
# Redis connection URL. Example: redis://localhost:6379/0
REDIS_URL=

# Intake context TTL in seconds (Stage 1 -> Stage 2 handoff window)
INTAKE_CACHE_TTL_SECONDS=3600

# In-memory fallback capacity when Redis is unavailable
MAX_CACHED_INTAKES=1000

# ---------------------------------------------------------------------------
# Admin controls (Phase 9)
# ---------------------------------------------------------------------------
# Set a strong random string to enable the /admin/* endpoints.
# Leave empty to disable admin access entirely.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000
